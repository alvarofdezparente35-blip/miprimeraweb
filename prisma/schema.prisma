generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Order {
  id        String   @id @default(uuid())
  name      String
  email     String
  address   String
  city      String   @default("")
  zip       String   @default("")
  quantity  Int      @default(1)
  total     Float
  status    String   @default("pending")
  created   DateTime @default(now())
}

model RefreshToken {
  jti       String   @id
  role      String
  expiresAt DateTime
}

model Admin {
  id        Int      @id @default(autoincrement())
  password  String
  createdAt DateTime @default(now())
}
