# ── Generar secrets seguros ──────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NODE_ENV=development
PORT=3001

# JWT (64 bytes hex cada uno)
JWT_SECRET=my-jwt-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=my-jwt-refresh-secret-min-32-chars!!

# Cookie (32 bytes hex)
COOKIE_SECRET=my-cookie-secret-32-chars!!

# Admin
ADMIN_PASSWORD=admin123!

# Stripe (modo test por defecto)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3001

# Sentry (opcional — para tracking de errores en producción)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email (Resend — opcional, modo demo si no se configura)
RESEND_API_KEY=
EMAIL_FROM=pedidos@lumicharge.es
